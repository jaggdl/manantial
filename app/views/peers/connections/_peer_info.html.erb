<% profile = connection.peer_profile %>
<% display_name = profile&.display_name || connection.hostname %>
<% fallback_letter = display_name.to_s.first.upcase %>

<div class="flex items-center gap-3">
  <span class="w-2 h-2 <%= local_assigns[:status_color] %> rounded-full"></span>
  <% if profile&.avatar_url.present? %>
    <%= image_tag profile.avatar_url, class: "w-8 h-8 rounded-full object-cover border border-zinc-700" %>
  <% else %>
    <div class="w-8 h-8 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center">
      <span class="font-mono text-xs text-zinc-500 uppercase"><%= fallback_letter %></span>
    </div>
  <% end %>
  <span class="font-mono text-sm <%= local_assigns[:text_color] || "text-zinc-300" %>"><%= display_name %></span>
</div>
