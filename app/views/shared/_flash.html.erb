<%# Flash messages following Nothing Design System %>
<%# Fixed position at top with close button - Space Mono, uppercase, bracket format %>

<% if flash.any? %>
  <div class="fixed top-6 left-1/2 -translate-x-1/2 z-50 space-y-2">
    <% flash.each do |type, message| %>
      <% next if message.blank? %>
      
      <%# Determine color and prefix based on flash type %>
      <% 
        color_class = case type.to_sym
        when :notice, :success
          "text-green-600"
        when :alert, :error
          "text-red-600"
        when :warning
          "text-amber-500"
        else
          "text-zinc-500"
        end
        
        prefix = case type.to_sym
        when :notice, :success
          "[OK"
        when :alert, :error
          "[ERROR"
        when :warning
          "[WARN"
        else
          "[INFO"
        end
      %>
      
      <div
        class="flex items-center gap-3 px-4 py-2 border border-zinc-700 bg-zinc-950/95 backdrop-blur-sm transition-all duration-300 ease-out w-[calc(100vw-48px)] max-w-md"
        data-controller="flash"
        data-action="mouseenter->flash#keep"
      >
        <p class="font-mono text-xs tracking-widest uppercase <%= color_class %>">
          <%= prefix %>: <%= message %> ]
        </p>
        
        <button 
          type="button"
          class="font-mono text-xs text-zinc-500 hover:text-zinc-200 transition-colors"
          data-action="flash#dismiss"
          aria-label="Close"
        >
          [X]
        </button>
      </div>
    <% end %>
  </div>
<% end %>
