<% size_class = local_assigns[:size] || "w-8 h-8" %>
<% text_class = local_assigns[:text_size] || "text-xs" %>
<% avatar_url = user.respond_to?(:avatar_url) ? user.avatar_url : (user.avatar.attached? ? user.avatar.variant(resize_to_limit: [128, 128]) : nil) %>

<% if avatar_url.present? %>
  <%= image_tag avatar_url, class: "#{size_class} rounded-full object-cover border border-zinc-700" %>
<% else %>
  <div class="<%= size_class %> rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center">
    <span class="font-mono <%= text_class %> text-zinc-500 uppercase">
      <%= user.name.to_s.first.upcase %>
    </span>
  </div>
<% end %>
