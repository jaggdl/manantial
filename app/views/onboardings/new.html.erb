<div class="max-w-md mx-auto mt-10 p-6 bg-white shadow rounded">
  <h1 class="text-2xl font-bold mb-4">Welcome!</h1>
  <p class="mb-6">This is a personal website. To get started, please create your account.</p>

  <%= form_with url: onboarding_path, method: :post, local: true do |f| %>
    <% if @user&.errors&.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
        <ul class="list-disc pl-5">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :email_address, class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email_address, required: true, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password, required: true, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2" %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700" %>
      <%= f.password_field :password_confirmation, required: true, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2" %>
    </div>

    <div>
      <%= f.submit "Create Account", class: "w-full bg-blue-600 text-white py-2 px-4 rounded hover:bg-blue-700 cursor-pointer" %>
    </div>
  <% end %>
</div>