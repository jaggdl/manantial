<div class="w-full flex items-center justify-center p-6">
  <div class="w-full max-w-md">
    <%# Primary: Hero headline %>
    <h1 class="font-display text-5xl text-white tracking-tight mb-2">
      Sign in
    </h1>

    <%# Secondary: Description %>
    <p class="font-sans text-base text-zinc-500 mb-12">
      Please enter your credentials to continue.
    </p>

    <%= form_with url: session_url, method: :post, local: true, class: "contents" do |f| %>
      <% if @user&.errors&.any? %>
        <div class="mb-6" role="alert">
          <span class="font-mono text-xs tracking-wide text-red-600 uppercase">[ ERROR ]</span>
          <ul class="mt-2 space-y-1">
            <% @user.errors.full_messages.each do |message| %>
              <li class="font-mono text-sm text-red-600"><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Form fields with Nothing-style labels %>
      <div class="mb-8">
        <%= f.label :email_address, class: "block font-mono text-xs tracking-widest text-zinc-500 uppercase mb-2" %>
        <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "w-full bg-transparent border-b border-zinc-700 focus:border-white font-mono text-base text-zinc-200 py-2 outline-none transition-colors" %>
      </div>

      <div class="mb-8">
        <%= f.label :password, class: "block font-mono text-xs tracking-widest text-zinc-500 uppercase mb-2" %>
        <%= f.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "w-full bg-transparent border-b border-zinc-700 focus:border-white font-mono text-base text-zinc-200 py-2 outline-none transition-colors" %>
      </div>

      <div class="mb-10 flex flex-col sm:flex-row sm:items-center sm:gap-4">
        <%# Primary action: pill button %>
        <div>
          <%= f.submit "SIGN IN", class: "w-full bg-white text-black font-mono text-sm uppercase tracking-wider py-3 px-6 rounded-full min-h-11 cursor-pointer hover:bg-zinc-200 transition-colors" %>
        </div>

        <%# Tertiary: Forgot password link %>
        <div class="mt-4 sm:mt-0">
          <%= link_to "Forgot password?", new_password_path, class: "font-mono text-xs tracking-wide text-zinc-500 hover:text-zinc-300 transition-colors uppercase" %>
        </div>
      </div>
    <% end %>

    <%# Tertiary: Metadata/footer %>
    <p class="mt-8 font-mono text-xs tracking-wide text-zinc-600 text-center uppercase">
      Manantial Latest v1.0
    </p>
  </div>
</div>
