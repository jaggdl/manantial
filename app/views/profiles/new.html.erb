<div class="w-full flex items-center justify-center p-6">
  <div class="w-full max-w-md">
    <%# Primary: Hero headline %>
    <h1 class="font-display text-5xl text-white tracking-tight mb-2">
      Welcome
    </h1>

    <%# Secondary: Description %>
    <p class="font-sans text-base text-zinc-500 mb-12">
      Create your account to get started.
    </p>

    <%= render "form", user: @user, url: onboarding_path, method: :post, submit_text: "CREATE ACCOUNT", password_required: true, full_width_submit: true %>

    <%# Tertiary: Metadata/footer %>
    <p class="mt-8 font-mono text-xs tracking-wide text-zinc-600 text-center uppercase">
      Manantial Latest v1.0
    </p>
  </div>
</div>
