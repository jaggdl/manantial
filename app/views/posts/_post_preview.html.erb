<article class="group border-b border-zinc-800 py-6 first:pt-0">
  <%= link_to post_preview.url, class: "block", target: post_preview.local? ? nil : "_blank", rel: post_preview.local? ? nil : "noopener" do %>
    <%# Avatar, name and time ago %>
    <div class="flex items-center gap-3 mb-4">
      <% if post_preview.user_avatar_url.present? %>
        <%= image_tag post_preview.user_avatar_url, class: "w-8 h-8 rounded-full object-cover border border-zinc-700" %>
      <% else %>
        <div class="w-8 h-8 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center">
          <span class="font-mono text-xs text-zinc-500 uppercase">
            <%= post_preview.user_name.to_s.first.upcase %>
          </span>
        </div>
      <% end %>
      <div class="flex flex-col">
        <span class="font-mono text-xs tracking-widest text-white uppercase">
          <%= post_preview.user_name %>
        </span>
        <span class="font-mono text-[10px] tracking-widest text-zinc-600 uppercase">
          <%= time_ago_in_words(post_preview.created_at) %> AGO
        </span>
      </div>
    </div>

    <% if post_preview.title.present? %>
      <h2 class="font-display text-xl md:text-2xl tracking-tight text-white mb-3 group-hover:text-zinc-300 transition-colors leading-tight">
        <%= post_preview.title %>
      </h2>
    <% end %>

    <p class="font-sans text-base text-white leading-relaxed">
      <%= post_preview.preview_text %>
    </p>

    <%= render 'posts/image_grid', images: post_preview.preview_image_urls if post_preview.preview_image_urls.any? %>

    <% if post_preview.article? %>
      <div class="mt-4">
        <span class="font-mono text-sm tracking-widest text-zinc-600 uppercase border border-zinc-700 px-2 py-0.5 rounded-full">
          ARTICLE
        </span>
      </div>
    <% end %>
  <% end %>
</article>
