<div class="">
  <% post_title = @post.title&.strip || @post.body.to_plain_text.truncate(100) %>
  <% post_description = @post.body.to_plain_text.truncate(280) %>

  <% og_title = post_title.truncate(55) %>
  <% og_description = post_description.truncate(140) %>

  <% content_for(:title) do %>
    <%= post_title %> - <%= Current.owner.name %>
  <% end %>

  <% content_for(:head) do %>
    <meta name="description" content="<%= post_description %>">
    <link rel="canonical" href="<%= post_url(@post) %>">

    <meta property="og:type" content="article">
    <meta property="og:title" content="<%= og_title %>">
    <meta property="og:description" content="<%= og_description %>">
    <meta property="og:url" content="<%= post_url(@post) %>">
    <meta property="article:published_time" content="<%= @post.created_at.iso8601 %>">

    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= og_title %>">
    <meta name="twitter:description" content="<%= og_description %>">
  <% end %>

  <% content_for(:header_back) do %>
    <%= link_to posts_path, class: "font-mono text-sm tracking-widest text-zinc-500 uppercase hover:text-zinc-200 transition-colors" do %>
      <span class="mr-1">←</span> BACK
    <% end %>
  <% end %>

  <% content_for(:header_actions) do %>
    <% if Current.user == @post.user %>
      <div class="flex items-center gap-4">
        <%= link_to edit_post_path(@post), class: "font-mono text-sm tracking-widest text-zinc-500 uppercase hover:text-zinc-200 transition-colors" do %>
          EDIT
        <% end %>
        <%= button_to post_path(@post), method: :delete, class: "font-mono text-sm tracking-widest text-red-600 uppercase hover:text-red-500 transition-colors bg-transparent border-none cursor-pointer", data: { turbo_confirm: "Delete this post?" } do %>
          DELETE
        <% end %>
      </div>
    <% end %>
  <% end %>

  <article class="max-w-3xl mx-auto">
    <% if @post.title.present? %>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl tracking-tight text-white mb-6 leading-tight">
        <%= @post.title %>
      </h1>
    <% end %>

    <div class="flex items-center gap-4 mb-8 pb-8 border-b border-zinc-800">
        <span class="font-display text-xl md:text-2xl tracking-tight text-white uppercase">
          <%= @post.post_type %>
        </span>
    </div>

    <div class="prose prose-invert prose-zinc max-w-none">
      <%= @post.body %>
    </div>

    <div class="flex items-center gap-4 mb-12 pb-8 border-b border-zinc-800">
      <span class="font-mono text-sm tracking-widest text-zinc-600 uppercase">
        <%= @post.formatted_date %>
      </span>
    </div>
  </article>
</div>
