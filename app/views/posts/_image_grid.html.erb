<% images = images.first(4) %>
<% count = images.count %>
<div class="mt-4 rounded-xl overflow-hidden border border-zinc-700
  <%= 'grid grid-cols-2 grid-rows-2 aspect-square' if count >= 4 %>
  <%= 'grid grid-cols-2 aspect-[2/1]' if count == 2 %>
  <%= 'grid grid-cols-2 grid-rows-2 aspect-square' if count == 3 %>
">
  <% images.each_with_index do |blob, index| %>
    <% if count == 1 %>
      <%= image_tag(
            blob.representation(resize_to_limit: [1200, 800]),
            alt: blob.filename.to_s,
            loading: "lazy",
            class: "w-full h-full object-cover"
          ) %>
    <% elsif count == 2 %>
      <%= image_tag(
            blob.representation(resize_to_limit: [800, 600]),
            alt: blob.filename.to_s,
            loading: "lazy",
            class: "w-full h-full object-cover"
          ) %>
    <% elsif count == 3 %>
      <% if index == 0 %>
        <%= image_tag(
              blob.representation(resize_to_limit: [800, 800]),
              alt: blob.filename.to_s,
              loading: "lazy",
              class: "w-full h-full object-cover row-span-2"
            ) %>
      <% elsif index == 1 %>
        <%= image_tag(
              blob.representation(resize_to_limit: [800, 400]),
              alt: blob.filename.to_s,
              loading: "lazy",
              class: "w-full h-full object-cover border-l border-b border-zinc-700"
            ) %>
      <% else %>
        <%= image_tag(
              blob.representation(resize_to_limit: [800, 400]),
              alt: blob.filename.to_s,
              loading: "lazy",
              class: "w-full h-full object-cover border-l border-zinc-700"
            ) %>
      <% end %>
    <% else # count == 4 %>
      <%= image_tag(
            blob.representation(resize_to_limit: [600, 600]),
            alt: blob.filename.to_s,
            loading: "lazy",
            class: "w-full h-full object-cover #{'border-r border-zinc-700' if index == 0 || index == 2} #{'border-b border-zinc-700' if index == 0 || index == 1}"
          ) %>
    <% end %>
  <% end %>
</div>
