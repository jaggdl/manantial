<% images = images.first(4) %>
<% count = images.count %>
<div class="mt-4 rounded-xl overflow-hidden border border-zinc-700
  <%= 'grid grid-cols-2 grid-rows-2 aspect-square' if count >= 4 %>
  <%= 'grid grid-cols-2 aspect-[2/1]' if count == 2 %>
  <%= 'grid grid-cols-2 grid-rows-2 aspect-square' if count == 3 %>
">
  <% images.each_with_index do |url, index| %>
    <% if count == 1 %>
      <%= image_tag(url, alt: "", loading: "lazy", class: "w-full h-full object-cover") %>
    <% elsif count == 2 %>
      <%= image_tag(url, alt: "", loading: "lazy", class: "w-full h-full object-cover") %>
    <% elsif count == 3 %>
      <% if index == 0 %>
        <%= image_tag(url, alt: "", loading: "lazy", class: "w-full h-full object-cover row-span-2") %>
      <% else %>
        <%= image_tag(url, alt: "", loading: "lazy", class: "w-full h-full object-cover border-l border-zinc-700") %>
      <% end %>
    <% else # count == 4 %>
      <%= image_tag(url, alt: "", loading: "lazy", class: "w-full h-full object-cover #{'border-r border-zinc-700' if index == 0 || index == 2} #{'border-b border-zinc-700' if index == 0 || index == 1}") %>
    <% end %>
  <% end %>
</div>
