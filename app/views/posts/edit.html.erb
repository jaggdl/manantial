<div class="min-h-screen flex flex-col">
  <div class="flex items-center justify-between py-6 border-b border-zinc-800 mb-12">
    <%= link_to posts_path, class: "font-mono text-[11px] tracking-widest text-zinc-500 uppercase hover:text-zinc-200 transition-colors" do %>
      <span class="mr-1">←</span> BACK
    <% end %>
  </div>

  <div class="flex-1 flex flex-col items-center px-6">
    <div class="w-full max-w-2xl">
      <h1 class="font-display text-4xl md:text-5xl tracking-tight text-white mb-2">
        EDIT POST
      </h1>
      <p class="font-sans text-base text-zinc-500 mb-12">
        Update your content
      </p>

      <%= render "form", post: @post %>
    </div>
  </div>
</div>