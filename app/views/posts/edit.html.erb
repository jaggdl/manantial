<div class="flex flex-col">
  <% content_for(:header_back) do %>
    <%= link_to posts_path, class: "font-mono text-sm tracking-widest text-zinc-500 uppercase hover:text-zinc-200 transition-colors" do %>
      <span class="mr-1">←</span> BACK
    <% end %>
  <% end %>

  <div class="flex-1 flex flex-col items-center px-6">
    <div class="w-full max-w-2xl">
      <h1 class="font-display text-4xl md:text-5xl tracking-tight text-white mb-2">
        EDIT POST
      </h1>
      <p class="font-sans text-base text-zinc-500 mb-12">
        Update your content
      </p>

      <%= render "form", post: @post %>
    </div>
  </div>
</div>
